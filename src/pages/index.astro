  <script>
    import Lenis from 'lenis';

    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      orientation: 'vertical',
      smoothWheel: true,
    });

    const nav = document.getElementById('nav-top');
    lenis.on('scroll', ({ scroll }) => {
      nav.classList.toggle('scrolled', scroll > 60);

      const blob = document.getElementById('suaje-blob');
      const section = document.getElementById('suaje-section');
      if (blob && section) {
        const rect = section.getBoundingClientRect();
        const progress = -rect.top / window.innerHeight;
        blob.style.transform = `translateY(calc(-50% + ${progress * 90}px))`;
      }
    });

    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  </script>

