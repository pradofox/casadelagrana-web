    .sistema-title {
      grid-column: 1 / -1;
      font-family: var(--font-serif);
      font-weight: var(--w-medium);
      font-size: clamp(3rem, 8vw, 8rem);
      line-height: 0.92;
      letter-spacing: -0.01em;
      text-transform: uppercase;
      color: var(--text-dark);
      margin-top: var(--space-md);
    }
    .sistema-body {
      grid-column: 2;
      align-self: end;
      max-width: 46ch;
      font-family: var(--font-sans);
      font-weight: 300;
      font-size: 15px;
      line-height: 1.7;
      color: var(--text-dark);
      margin-top: var(--space-md);
    }

    .module {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: 1fr 4fr;
      gap: var(--space-xl);
      padding-top: var(--space-xl);
      align-items: start;
    }
    .module-label {
      font-family: var(--font-mono);
      font-weight: var(--w-base);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--text-grana);
    }

    /* Paleta */
    .paleta {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 4px;
    }
    .paleta-chip {
      display: flex;
      flex-direction: column;
    }
    .paleta-swatch {
      aspect-ratio: 1;
      width: 100%;
    }
    .paleta-info {
      padding: var(--space-sm) var(--space-xs) 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
