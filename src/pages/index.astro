---
const title = "Casa de la Grana · Centro cultural";
const description = "Centro cultural dedicado a la preservación de la grana cochinilla y su significado histórico. Naturaleza, historia y cultura en Oaxaca.";
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/images/img-01-hero.jpg" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/images/isotipo-rojo.svg" />
  <style>
    /* ---- FONTS ---- */
    @font-face {
      font-family: 'Chivo';
      src: url('/fonts/Chivo-VariableFont_wght.ttf') format('truetype');
      font-weight: 100 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Chivo';
      src: url('/fonts/Chivo-Italic-VariableFont_wght.ttf') format('truetype');
      font-weight: 100 900;
      font-style: italic;
      font-display: swap;
    }
    @font-face {
      font-family: 'ChivoMono';
      src: url('/fonts/ChivoMono-VariableFont_wght.ttf') format('truetype');
      font-weight: 100 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Koper';
      src: url('/fonts/Koper-Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    /* ---- TOKENS ---- */
    :root {
      --negro:      #231C1A;
      --crema:      #F7F3F0;
      --grana:      #A31300;
      --nduku:      #66123C;
      --buganvilia: #E2ACC5;
      --achiote:    #D87239;

      --font-mono: 'ChivoMono', monospace;
      --font-sans: 'Chivo', sans-serif;
      --font-serif: 'Koper', serif;
    }

    /* ---- RESET ---- */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: auto; } /* Lenis handles scroll */
    body {
      font-family: var(--font-sans);
      background: var(--crema);
      color: var(--negro);
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
    }
    img { display: block; max-width: 100%; height: auto; }
    a { color: inherit; text-decoration: none; }

    /* ---- NAV ---- */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.1rem 2.5rem;
      background: rgba(247, 243, 240, 0.94);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(35, 28, 26, 0.07);
    }
    .nav-logo {
      display: flex;
      align-items: center;
      line-height: 1;
    }
    .nav-logo img {
      height: 22px;
      width: auto;
      display: block;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--negro);
      opacity: 0.5;
      transition: opacity 0.2s;
    }
    .nav-links a:hover { opacity: 1; }

    /* ---- HERO ---- */
    .hero {
      position: relative;
      height: 100svh;
      min-height: 620px;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        160deg,
        rgba(35, 28, 26, 0.72) 0%,
        rgba(35, 28, 26, 0.45) 50%,
        rgba(35, 28, 26, 0.78) 100%
      );
    }
    .hero-content {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 2.5rem 4rem;
    }
    .hero-eyebrow {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--buganvilia);
      margin-bottom: 1rem;
    }
    .hero-title {
      font-family: var(--font-mono);
      font-weight: 200;
      font-size: clamp(3.5rem, 9vw, 7.5rem);
      letter-spacing: 0.03em;
      line-height: 0.92;
      color: var(--crema);
      text-transform: uppercase;
    }
    .hero-sub {
      margin-top: 1.75rem;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(247, 243, 240, 0.5);
    }

    /* ---- TICKER ---- */
    .ticker {
      overflow: hidden;
      background: var(--grana);
      padding: 0.8rem 0;
      white-space: nowrap;
    }
    .ticker-track {
      display: inline-flex;
      animation: ticker 30s linear infinite;
    }
    .ticker-track span {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 300;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--crema);
      padding-right: 3.5rem;
    }
    .ticker-track .dot {
      color: rgba(247, 243, 240, 0.4);
      padding-right: 3.5rem;
    }
    @keyframes ticker {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ---- MANIFESTO ---- */
    .manifesto {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .manifesto-text {
      padding: 6rem 4rem 6rem 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .section-label {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--grana);
      margin-bottom: 2rem;
    }
    .manifesto-heading {
      font-family: var(--font-mono);
      font-weight: 300;
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      line-height: 1.1;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: var(--grana);
      margin-bottom: 2rem;
    }
    .manifesto-body {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      line-height: 1.8;
      color: rgba(35, 28, 26, 0.88);
      max-width: 44ch;
    }
    .manifesto-body p + p { margin-top: 1em; }
    .manifesto-img {
      overflow: hidden;
      min-height: 500px;
    }
    .manifesto-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.7s ease;
    }
    .manifesto-img:hover img { transform: scale(1.03); }

    /* ---- QUOTE ---- */
    .quote-block {
      background: var(--nduku);
      padding: 7rem 2.5rem;
      text-align: center;
    }
    .quote-text {
      font-family: var(--font-serif);
      font-size: clamp(1.5rem, 3.2vw, 2.4rem);
      line-height: 1.45;
      color: var(--buganvilia);
      max-width: 820px;
      margin: 0 auto;
      font-style: italic;
    }
    .quote-attr {
      display: block;
      margin-top: 2.5rem;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(226, 172, 197, 0.45);
      font-style: normal;
    }

    /* ---- GALLERY ---- */
    .gallery-section {
      padding: 5rem 2.5rem 4rem;
      background: var(--crema);
    }
    .gallery-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 2.5rem;
    }
    .gallery-title {
      font-family: var(--font-mono);
      font-weight: 300;
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--negro);
    }
    .gallery-count {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(35, 28, 26, 0.35);
    }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.4rem;
    }
    .gallery-item {
      overflow: hidden;
      background: rgba(35, 28, 26, 0.06);
    }
    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .gallery-item:hover img { transform: scale(1.04); }
    .gallery-item.tall { grid-row: span 2; }
    .gallery-item.wide { grid-column: span 2; }

    .products-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0.4rem;
      margin-top: 0.4rem;
    }
    .product-item {
      aspect-ratio: 1;
      overflow: hidden;
      background: rgba(35, 28, 26, 0.03);
    }
    .product-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }
    .product-item:hover img { transform: scale(1.04); }

    /* ---- BRIDGE ---- */
    .bridge {
      background: var(--negro);
      padding: 6rem 2.5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .bridge .section-label { color: var(--achiote); }
    .bridge-heading {
      font-family: var(--font-mono);
      font-weight: 200;
      font-size: clamp(2rem, 3.5vw, 3rem);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--crema);
      margin-bottom: 1.5rem;
      line-height: 1.05;
    }
    .bridge-body {
      font-family: var(--font-sans);
      font-size: 0.9rem;
      line-height: 1.8;
      color: rgba(247, 243, 240, 0.55);
      margin-bottom: 2.5rem;
      max-width: 42ch;
    }
    .bridge-links { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .btn {
      display: inline-flex;
      align-items: center;
      padding: 0.65rem 1.4rem;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      border: 1px solid currentColor;
      transition: background 0.2s, color 0.2s;
    }
    .btn-grana {
      background: var(--grana);
      color: var(--crema);
      border-color: var(--grana);
    }
    .btn-grana:hover { background: transparent; color: var(--grana); }
    .btn-light {
      color: rgba(247, 243, 240, 0.6);
      border-color: rgba(247, 243, 240, 0.25);
    }
    .btn-light:hover { background: var(--crema); color: var(--negro); border-color: var(--crema); }

    .bridge-img {
      overflow: hidden;
      aspect-ratio: 4/5;
      max-height: 540px;
    }
    .bridge-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* ---- FOOTER ---- */
    footer {
      background: var(--crema);
      border-top: 1px solid rgba(35, 28, 26, 0.1);
      padding: 3rem 2.5rem;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 2rem;
    }
    .footer-contact address {
      font-style: normal;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.05em;
      line-height: 2;
      color: rgba(35, 28, 26, 0.6);
    }
    .footer-contact a:hover { color: var(--grana); }
    .footer-wordmark {
      text-align: center;
    }
    .footer-logo img {
      height: 28px;
      width: auto;
      display: block;
      margin: 0 auto;
    }
    .footer-sub {
      display: block;
      margin-top: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.58rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(35, 28, 26, 0.3);
      text-align: center;
    }
    .footer-copy {
      text-align: right;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      color: rgba(35, 28, 26, 0.3);
    }

    /* ---- RESPONSIVE ---- */
    @media (max-width: 900px) {
      nav { padding: 0.9rem 1.25rem; }
      .nav-links { display: none; }
      .hero-content { padding: 0 1.25rem 3rem; }
      .manifesto { grid-template-columns: 1fr; }
      .manifesto-text { padding: 4rem 1.25rem; }
      .manifesto-img { min-height: 260px; order: -1; }
      .gallery-section { padding: 4rem 1.25rem 3rem; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .products-strip { grid-template-columns: repeat(2, 1fr); }
      .bridge { grid-template-columns: 1fr; padding: 4rem 1.25rem; gap: 2rem; }
      .bridge-img { aspect-ratio: 16/9; max-height: 240px; }
      footer { grid-template-columns: 1fr; text-align: center; gap: 2rem; }
      .footer-copy { text-align: center; }
      .footer-wordmark { order: -1; }
      .footer-contact address { text-align: center; }
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav>
    <a href="/" class="nav-logo" aria-label="Casa de la Grana">
      <img src="/images/logo-negro.svg" alt="Casa de la Grana" />
    </a>
    <ul class="nav-links">
      <li><a href="https://www.instagram.com/nocheztlicalli/" target="_blank" rel="noopener">Instagram</a></li>
      <li><a href="https://nocheztlicalli.com" target="_blank" rel="noopener">Nocheztlicalli</a></li>
      <li><a href="#contacto">Contacto</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <img
      class="hero-bg"
      src="/images/img-01-hero.jpg"
      alt="Grana cochinilla - Casa de la Grana Oaxaca"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Centro cultural &middot; Oaxaca</p>
      <h1 class="hero-title">Descubre<br/>el secreto</h1>
      <p class="hero-sub">Naturaleza &middot; Historia &middot; Cultura</p>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      <span>Tradición</span><span class="dot">&middot;</span>
      <span>Arte</span><span class="dot">&middot;</span>
      <span>Preservación</span><span class="dot">&middot;</span>
      <span>Grana Cochinilla</span><span class="dot">&middot;</span>
      <span>Oaxaca</span><span class="dot">&middot;</span>
      <span>Nocheztlicalli</span><span class="dot">&middot;</span>
      <span>Tintes Naturales</span><span class="dot">&middot;</span>
      <span>Patrimonio</span><span class="dot">&middot;</span>
      <span>Tradición</span><span class="dot">&middot;</span>
      <span>Arte</span><span class="dot">&middot;</span>
      <span>Preservación</span><span class="dot">&middot;</span>
      <span>Grana Cochinilla</span><span class="dot">&middot;</span>
      <span>Oaxaca</span><span class="dot">&middot;</span>
      <span>Nocheztlicalli</span><span class="dot">&middot;</span>
      <span>Tintes Naturales</span><span class="dot">&middot;</span>
      <span>Patrimonio</span><span class="dot">&middot;</span>
    </div>
  </div>

  <!-- MANIFESTO -->
  <section class="manifesto">
    <div class="manifesto-text">
      <p class="section-label">01 &mdash; Nuestro pasado en la actualidad</p>
      <h2 class="manifesto-heading">La grana que<br/>colorea nuestra<br/>historia</h2>
      <div class="manifesto-body">
        <p>Casa de la Grana preserva la práctica tradicional del cultivo de la grana cochinilla y comparte su significado histórico. Un espacio donde el conocimiento científico se entrelaza con la experiencia creativa.</p>
        <p>Desde Oaxaca, rescatamos el legado de Nocheztlicalli - el insecto sagrado que tiñó imperios y continúa siendo fuente de vida y arte para nuestra comunidad.</p>
      </div>
    </div>
    <div class="manifesto-img">
      <img
        src="/images/img-11.jpg"
        alt="Cochinilla y tintes naturales"
        loading="lazy"
      />
    </div>
  </section>

  <!-- QUOTE -->
  <section class="quote-block">
    <blockquote>
      <p class="quote-text">"nuestras raíces no solo nos definen, sino que la naturaleza nos ofrece enseñanzas"</p>
      <cite class="quote-attr">Nocheztlicalli &middot; Casa de la Grana</cite>
    </blockquote>
  </section>

  <!-- GALLERY -->
  <section class="gallery-section">
    <div class="gallery-header">
      <h2 class="gallery-title">Galería</h2>
      <span class="gallery-count">Proyecto CEDIM &middot; 2024</span>
    </div>

    <div class="gallery-grid">
      <div class="gallery-item wide" style="aspect-ratio:16/7;">
        <img src="/images/img-05.jpg" alt="Casa de la Grana" loading="lazy" />
      </div>
      <div class="gallery-item tall" style="aspect-ratio:2/3;">
        <img src="/images/img-08.jpg" alt="Grana cochinilla" loading="lazy" />
      </div>
      <div class="gallery-item" style="aspect-ratio:1;">
        <img src="/images/img-06.jpg" alt="Tintes naturales" loading="lazy" />
      </div>
      <div class="gallery-item" style="aspect-ratio:1;">
        <img src="/images/img-07.jpg" alt="Textiles Oaxaca" loading="lazy" />
      </div>
      <div class="gallery-item" style="aspect-ratio:1;">
        <img src="/images/img-09.jpg" alt="Cochinilla" loading="lazy" />
      </div>
      <div class="gallery-item" style="aspect-ratio:1;">
        <img src="/images/img-10.jpg" alt="Arte natural" loading="lazy" />
      </div>
      <div class="gallery-item" style="aspect-ratio:3/4;">
        <img src="/images/img-15.jpg" alt="Proceso de tinte" loading="lazy" />
      </div>
      <div class="gallery-item" style="aspect-ratio:3/2;">
        <img src="/images/img-16.jpg" alt="Taller" loading="lazy" />
      </div>
    </div>

    <div class="products-strip">
      <div class="product-item">
        <img src="/images/brand-01.png" alt="Empaque grana" loading="lazy" />
      </div>
      <div class="product-item">
        <img src="/images/brand-02.png" alt="Empaque añil" loading="lazy" />
      </div>
      <div class="product-item">
        <img src="/images/brand-03.png" alt="Flyer teñido" loading="lazy" />
      </div>
      <div class="product-item">
        <img src="/images/brand-04.png" alt="Flyer shibori" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- BRIDGE -->
  <section class="bridge">
    <div class="bridge-text">
      <p class="section-label">02 &mdash; El proyecto vive</p>
      <h2 class="bridge-heading">Visita<br/>Nocheztlicalli</h2>
      <p class="bridge-body">Casa de la Grana nació como proyecto académico en CEDIM 2024. Hoy, la investigación y el espíritu del proyecto continúan vivos a través de Nocheztlicalli - su sitio, tienda y espacio de difusión.</p>
      <div class="bridge-links">
        <a href="https://nocheztlicalli.com" target="_blank" rel="noopener" class="btn btn-grana">nocheztlicalli.com</a>
        <a href="https://www.instagram.com/nocheztlicalli/" target="_blank" rel="noopener" class="btn btn-light">@nocheztlicalli</a>
      </div>
    </div>
    <div class="bridge-img">
      <img src="/images/img-13.png" alt="Nocheztlicalli" loading="lazy" />
    </div>
  </section>

  <!-- FOOTER -->
  <footer id="contacto">
    <div class="footer-contact">
      <p class="section-label" style="margin-bottom:0.75rem;">Contacto</p>
      <address>
        Nardos #616, Col. Ampliación Santa Lucía<br/>
        Santa Lucía del Camino, Oaxaca, México<br/>
        <br/>
        <a href="tel:9515702818">951 570 2818</a><br/>
        <a href="mailto:casadelagrana@gmail.com">casadelagrana@gmail.com</a>
      </address>
    </div>

    <div class="footer-wordmark">
      <div class="footer-logo">
        <img src="/images/logo-negro.svg" alt="Casa de la Grana" />
      </div>
      <span class="footer-sub">Centro cultural &middot; Oaxaca</span>
    </div>

    <div class="footer-copy">
      <p>&copy; {new Date().getFullYear()}</p>
    </div>
  </footer>

  <!-- LENIS SMOOTH SCROLL -->
  <script>
    import Lenis from 'lenis';

    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      orientation: 'vertical',
      smoothWheel: true,
    });

    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }
    requestAnimationFrame(raf);
  </script>

</body>
</html>
