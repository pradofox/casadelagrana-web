  <script>
    import { gsap } from 'gsap';

    // ── LOADER ──────────────────────────────────────────────────────────────
    // Tres composiciones tipográficas planeadas para DESCUBRE / EL / SECRETO.
    // Cada entrada: [x, y] offset en px desde el centro del viewport.
    //
    //   [0] = DESCUBRE   [1] = EL   [2] = SECRETO

    // Composiciones diseñadas a 1200px de referencia.
    // Se escalan proporcionalmente para que se vean igual en cualquier viewport.
    const s = Math.min(1, window.innerWidth / 1200);

    // Renglones fijos: y ∈ { -100, 0, 100 }. Sin valores intermedios.
    const comps = [
      // A — DESCUBRE arriba-izq · EL medio-der · SECRETO abajo-izq
      [[-180, -100], [ 260,   0], [ -60, 100]],
      // B — DESCUBRE arriba-der · EL medio-izq · SECRETO abajo-der
      [[ 140, -100], [-250,   0], [ 100, 100]],
      // C — DESCUBRE arriba · EL y SECRETO en el mismo renglón abajo
      [[ -40, -100], [-260, 100], [ 120, 100]],
    ].map(comp => comp.map(([x, y]) => [x * s, y * s]));

    const loader = document.getElementById('loader');
    const words  = ['lw-a', 'lw-b', 'lw-c'].map(id => document.getElementById(id));

    // Bloquear scroll durante el loader
    document.body.style.overflow = 'hidden';

    // Posición inicial = comp A, invisible
    words.forEach((el, i) => {
      gsap.set(el, {
        xPercent: -50,
        yPercent: -50,
        x: comps[0][i][0],
        y: comps[0][i][1],
        opacity: 0,
      });
    });

    const tl = gsap.timeline();

    // Fade-in rápido en comp A
    tl.to(words, {
      opacity: 1,
      duration: 0.14,
      stagger: 0.05,
      ease: 'power2.out',
    })

    // A → B
    .to(words, {
      x: (i) => comps[1][i][0],
      y: (i) => comps[1][i][1],
      duration: 0.42,
      stagger: 0.03,
      ease: 'power3.inOut',
      delay: 0.12,
    })

    // B → C
    .to(words, {
      x: (i) => comps[2][i][0],
      y: (i) => comps[2][i][1],
      duration: 0.38,
      stagger: 0.03,
      ease: 'power3.inOut',
      delay: 0.14,
    })

    // Fade-out
    .to(loader, {
      opacity: 0,
      duration: 0.22,
      ease: 'power2.inOut',
      delay: 0.1,
      onComplete: () => {
        loader.remove();
        document.body.style.overflow = '';
        if (window.__lenis) window.__lenis.start();
      },
    });
    // ── /LOADER ─────────────────────────────────────────────────────────────
  </script>

  <script>
    import Lenis from 'lenis';

    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });
    window.__lenis = lenis;

    // Pausar Lenis mientras corre el loader
    if (document.getElementById('loader')) lenis.stop();

    const nav = document.getElementById('nav');
    lenis.on('scroll', ({ scroll }) => {
      nav.classList.toggle('scrolled', scroll > 80);
    });

    function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    // Menu overlay
    const menuToggle = document.getElementById('menu-toggle');
    const menuOverlay = document.getElementById('menu-overlay');
    const setMenu = (open) => {
      document.body.classList.toggle('menu-open', open);
      menuOverlay.classList.toggle('open', open);
      menuToggle.setAttribute('aria-expanded', String(open));
      menuOverlay.setAttribute('aria-hidden', String(!open));
      menuToggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      menuToggle.querySelector('.label').textContent = open ? 'Cerrar' : 'Menú';
      if (open) lenis.stop(); else lenis.start();
    };
    menuToggle.addEventListener('click', () => setMenu(!menuOverlay.classList.contains('open')));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuOverlay.classList.contains('open')) setMenu(false);
    });
    menuOverlay.querySelectorAll('.menu-item').forEach(a => a.addEventListener('click', () => setMenu(false)));

    // ── LIGHTBOX ─────────────────────────────────────────────────────────────
    const lightbox = document.getElementById('lightbox');
    const lbImg    = document.getElementById('lb-img');

    // Todas las imágenes de contenido (excluye logos y decorativas)
    const lbImages = [
      ...document.querySelectorAll(
        '.fg img, .grana-img img, .piece-img img, .bridge-img img'
      )
    ];
    let lbIdx = 0;

    const openLB = (idx) => {
      lbIdx = idx;
      lbImg.src = lbImages[idx].src;
      lbImg.alt = lbImages[idx].alt;
      lightbox.classList.add('open');
      lightbox.removeAttribute('aria-hidden');
      lenis.stop();
    };

    const closeLB = () => {
      lightbox.classList.remove('open');
      lightbox.setAttribute('aria-hidden', 'true');
      lenis.start();
    };

    lbImages.forEach((img, i) => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => openLB(i));
    });

    document.getElementById('lb-close').addEventListener('click', closeLB);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLB(); });

    document.getElementById('lb-prev').addEventListener('click', (e) => {
      e.stopPropagation();
      openLB((lbIdx - 1 + lbImages.length) % lbImages.length);
    });
    document.getElementById('lb-next').addEventListener('click', (e) => {
      e.stopPropagation();
      openLB((lbIdx + 1) % lbImages.length);
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('open')) return;
      if (e.key === 'Escape')     closeLB();
      if (e.key === 'ArrowLeft')  openLB((lbIdx - 1 + lbImages.length) % lbImages.length);
      if (e.key === 'ArrowRight') openLB((lbIdx + 1) % lbImages.length);
    });
    // ── /LIGHTBOX ────────────────────────────────────────────────────────────
  </script>

