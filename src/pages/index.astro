---
const title = "Casa de la Grana · Centro cultural";
const description = "Centro cultural dedicado a la preservación de la grana cochinilla y su significado histórico. Naturaleza, historia y cultura en Oaxaca.";
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="/images/img-05.jpg" />
  <link rel="icon" type="image/svg+xml" href="/images/isotipo-rojo.svg" />
  <style>
    /* ---- FONTS ---- */
    @font-face {
      font-family: 'ChivoMono';
      src: url('/fonts/ChivoMono-VariableFont_wght.ttf') format('truetype');
      font-weight: 100 900;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'Koper';
      src: url('/fonts/Koper-Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }

    /* ---- TOKENS ---- */
    :root {
      --surface-cream:   #f7f3f0;
      --surface-black:   #000000;
      --surface-grana:   #a31300;
      --text-dark:       #231c1a;
      --text-light:      #f7f3f0;
      --text-grana:      #a31300;
      --text-muted:      rgba(35,28,26,0.45);
      --text-muted-inv:  rgba(247,243,240,0.45);

      --font-mono:    'ChivoMono', monospace;
      --font-serif:   'Koper', serif;

      --w-heavy:  900;
      --w-base:   100;
      --w-medium: 400;

      --space-xs:  8px;
      --space-sm:  16px;
      --space-md:  24px;
      --space-lg:  40px;
      --space-xl:  80px;
      --space-2xl: 120px;

      --radius-pill: 9999px;
      --radius-sm:   4px;

      --ease: cubic-bezier(0.4, 0, 0.2, 1);
      --dur:  400ms;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        transition-duration: 0.01ms !important;
        animation-duration:  0.01ms !important;
      }
    }

    /* ---- RESET ---- */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: auto; }
    body {
      font-family: var(--font-mono);
      font-weight: var(--w-base);
      background: var(--surface-cream);
      color: var(--text-dark);
      font-size: 12px;
      line-height: 1.6;
      overflow-x: hidden;
    }
    img { display: block; max-width: 100%; height: auto; }
    a   { color: inherit; text-decoration: none; }

    /* ---- NAV ---- */
    .nav {
      position: fixed;
      inset: 0 0 auto;
      z-index: 100;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 var(--space-md);
      background: var(--surface-cream);
      border-bottom: 1px solid rgba(35,28,26,0.05);
    }
    .nav-logo img {
      height: 22px;
      width: auto;
      display: block;
    }
    .nav-right {
      display: flex;
      align-items: center;
      gap: var(--space-md);
    }
    .nav-lang {
      font-family: var(--font-mono);
      font-weight: var(--w-base);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-dark);
    }
    .nav-lang strong { font-weight: var(--w-medium); }
    .nav-cart {
      width: 32px; height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--text-grana);
    }
    .nav-cart svg { width: 22px; height: 22px; }

    /* ---- HERO ---- */
    .hero {
      position: relative;
      min-height: 100svh;
      background: #000;
      overflow: hidden;
      padding-top: 56px;
    }
    .hero-bg {
      position: absolute;
      inset: 56px 0 0 0;
      width: 100%;
      height: calc(100% - 56px);
      object-fit: cover;
      z-index: 0;
    }
    .hero-inner {
      position: relative;
      z-index: 1;
      min-height: calc(100svh - 56px);
    }
    .hero-word {
      position: absolute;
      font-family: var(--font-serif);
      font-weight: var(--w-medium);
      font-size: clamp(4.5rem, 13.5vw, 14rem);
      text-transform: uppercase;
      letter-spacing: -0.01em;
      line-height: 0.9;
      color: var(--text-light);
      white-space: nowrap;
    }
    .hero-word-l { top: var(--space-lg); left: -1.2vw; }
    .hero-word-r { bottom: var(--space-lg); right: -1.2vw; }
    .hero-tag {
      position: absolute;
      font-family: var(--font-mono);
      font-weight: var(--w-base);
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--text-light);
      white-space: nowrap;
    }
    .hero-tag-tr { top: calc(var(--space-lg) + 11.5vw); right: var(--space-lg); }
    .hero-tag-bl { bottom: calc(var(--space-lg) + 11.5vw); left: var(--space-lg); }

    /* ---- EXPOSITION ---- */
    .expo {
      background: var(--surface-black);
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .expo-text {
      padding: var(--space-xl) var(--space-lg);
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: var(--space-md);
    }
    .label {
      font-family: var(--font-mono);
      font-weight: var(--w-base);
      font-size: 9px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--text-grana);
    }
    .label-inv {
      color: var(--text-muted-inv);
    }
    .expo-heading {
      font-family: var(--font-mono);
      font-weight: var(--w-heavy);
      font-size: clamp(1.6rem, 3vw, 2.8rem);
      text-transform: uppercase;
      letter-spacing: -0.01em;
      line-height: 1.0;
      color: var(--text-light);
    }
    .expo-body {
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-muted-inv);
      max-width: 40ch;
    }
    .expo-img {
      overflow: hidden;
      min-height: 480px;
    }
    .expo-img img {
      width: 100%; height: 100%;
      object-fit: cover;
    }

    /* ---- BUTTONS ---- */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: var(--space-xs);
      padding: 12px var(--space-md);
      font-family: var(--font-mono);
      font-weight: var(--w-medium);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      border-radius: var(--radius-pill);
      border: 1px solid transparent;
      min-height: 44px;
      cursor: pointer;
      transition: background var(--dur) var(--ease),
                  color var(--dur) var(--ease),
                  border-color var(--dur) var(--ease);
    }
    .btn-grana {
      background: var(--surface-grana);
      color: var(--text-light);
      border-color: var(--surface-grana);
    }
    .btn-grana:hover { background: #8a1000; border-color: #8a1000; }
    .btn-outline-light {
      background: transparent;
      color: var(--text-light);
      border-color: rgba(247,243,240,0.3);
    }
    .btn-outline-light:hover { background: var(--text-light); color: var(--text-dark); border-color: var(--text-light); }
    .btn-outline-dark {
      background: transparent;
      color: var(--text-dark);
      border-color: rgba(35,28,26,0.3);
    }
    .btn-outline-dark:hover { background: var(--text-dark); color: var(--text-light); border-color: var(--text-dark); }

    /* ---- MANIFESTO ---- */
    .manifesto {
      background: var(--surface-cream);
      padding: var(--space-xl) var(--space-lg);
    }
    .manifesto-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
      align-items: start;
      margin-bottom: var(--space-xl);
    }
    .manifesto-heading {
      font-family: var(--font-mono);
      font-weight: var(--w-heavy);
      font-size: clamp(2rem, 4.5vw, 4rem);
      text-transform: uppercase;
      letter-spacing: -0.01em;
      line-height: 0.92;
      color: var(--text-grana);
    }
    .manifesto-body {
      font-size: 12px;
      line-height: 1.9;
      color: var(--text-muted);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding-top: var(--space-sm);
    }
    .manifesto-body p + p { margin-top: 1em; }
    .manifesto-imgs {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 4px;
      height: 480px;
    }
    .manifesto-img {
      overflow: hidden;
    }
    .manifesto-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform var(--dur) var(--ease);
    }
    .manifesto-img:hover img { transform: scale(1.04); }

    /* ---- FAVORITOS ---- */
    .favoritos {
      background: var(--surface-cream);
      padding: var(--space-xl) var(--space-lg);
    }
    .favoritos-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr;
      align-items: center;
      gap: var(--space-sm);
    }
    .favoritos-word {
      font-family: var(--font-mono);
      font-weight: var(--w-heavy);
      font-size: clamp(2.5rem, 5.5vw, 5rem);
      text-transform: uppercase;
      letter-spacing: -0.02em;
      line-height: 0.9;
      color: var(--text-dark);
    }
    .favoritos-word.right {
      text-align: right;
    }
    .favoritos-cards {
      grid-column: span 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-sm);
    }
    .product-card {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }
    .product-img {
      aspect-ratio: 3/4;
      border-radius: var(--radius-sm);
      overflow: hidden;
      background: rgba(35,28,26,0.04);
    }
    .product-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform var(--dur) var(--ease);
    }
    .product-card:hover .product-img img { transform: scale(1.05); }
    .product-name {
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dark);
    }
    .product-detail {
      font-size: 9px;
      letter-spacing: 0.08em;
      color: var(--text-muted);
    }

    /* ---- TINA Y AMIGOS ---- */
    .tina {
      background: var(--surface-cream);
      border-top: 1px solid rgba(35,28,26,0.08);
    }
    .tina-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .tina-text {
      padding: var(--space-xl) var(--space-lg);
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: var(--space-md);
    }
    .tina-heading {
      font-family: var(--font-mono);
      font-weight: var(--w-heavy);
      font-size: clamp(2rem, 4vw, 3.8rem);
      text-transform: uppercase;
      letter-spacing: -0.02em;
      line-height: 0.9;
      color: var(--text-dark);
    }
    .tina-sub {
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-muted);
      max-width: 38ch;
    }
    .tina-imgs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      gap: 4px;
      min-height: 480px;
    }
    .tina-img {
      overflow: hidden;
    }
    .tina-img:first-child {
      grid-row: span 2;
    }
    .tina-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform var(--dur) var(--ease);
    }
    .tina-img:hover img { transform: scale(1.04); }

    /* ---- QUOTE ---- */
    .quote {
      background: var(--surface-black);
      padding: var(--space-xl) var(--space-lg);
      text-align: center;
    }
    .quote-text {
      font-family: var(--font-serif);
      font-weight: var(--w-medium);
      font-size: clamp(1.4rem, 3vw, 2.4rem);
      line-height: 1.45;
      color: var(--text-light);
      max-width: 800px;
      margin: 0 auto;
      font-style: italic;
    }
    .quote-attr {
      display: block;
      margin-top: var(--space-md);
      font-family: var(--font-mono);
      font-weight: var(--w-base);
      font-size: 9px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--text-muted-inv);
    }

    /* ---- BRIDGE ---- */
    .bridge {
      background: var(--surface-black);
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-top: 1px solid rgba(247,243,240,0.06);
    }
    .bridge-text {
      padding: var(--space-xl) var(--space-lg);
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: var(--space-md);
    }
    .bridge-heading {
      font-family: var(--font-mono);
      font-weight: var(--w-heavy);
      font-size: clamp(2rem, 4vw, 3.5rem);
      text-transform: uppercase;
      letter-spacing: -0.01em;
      line-height: 0.9;
      color: var(--text-light);
    }
    .bridge-body {
      font-size: 12px;
      line-height: 1.8;
      color: var(--text-muted-inv);
      max-width: 40ch;
    }
    .bridge-btns { display: flex; gap: var(--space-xs); flex-wrap: wrap; }
    .bridge-img {
      overflow: hidden;
      min-height: 480px;
    }
    .bridge-img img {
      width: 100%; height: 100%;
      object-fit: cover;
    }

    /* ---- FOOTER ---- */
    footer {
      background: var(--surface-cream);
      border-top: 1px solid rgba(35,28,26,0.08);
      padding: var(--space-lg);
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: var(--space-md);
    }
    .footer-contact {
      font-size: 10px;
      letter-spacing: 0.06em;
      line-height: 2;
      color: var(--text-muted);
    }
    .footer-contact a:hover { color: var(--text-grana); }
    .footer-logo img { height: 24px; width: auto; display: block; margin: 0 auto; }
    .footer-sub {
      display: block;
      text-align: center;
      margin-top: 6px;
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(35,28,26,0.25);
    }
    .footer-copy {
      text-align: right;
      font-size: 9px;
      letter-spacing: 0.1em;
      color: rgba(35,28,26,0.25);
    }

    /* ---- FLOATING NAV ---- */
    .float-nav {
      position: fixed;
      bottom: var(--space-md);
      left: 50%;
      transform: translateX(-50%);
      z-index: 98;
      display: flex;
      align-items: center;
      background: rgba(247,243,240,0.92);
      backdrop-filter: blur(14px);
      border: 1px solid rgba(35,28,26,0.1);
      border-radius: var(--radius-pill);
      white-space: nowrap;
    }
    .float-nav a {
      font-family: var(--font-mono);
      font-weight: var(--w-base);
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-dark);
      padding: 14px 18px;
      min-height: 44px;
      display: flex;
      align-items: center;
      transition: color var(--dur) var(--ease);
    }
    .float-nav a:hover { color: var(--text-grana); }
    .float-nav a:first-child { border-radius: var(--radius-pill) 0 0 var(--radius-pill); }
    .float-nav a:last-child  { border-radius: 0 var(--radius-pill) var(--radius-pill) 0; }

    /* ---- INTRO / BIENVENIDA ---- */
    .intro {
      position: relative;
      background: var(--surface-cream);
      min-height: 92vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      overflow: hidden;
      padding: var(--space-2xl) 0;
    }
    .intro-blob {
      position: relative;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }
    .intro-blob img {
      width: 115%;
      max-width: none;
      margin-left: -12%;
      display: block;
      filter: drop-shadow(0 0 0 transparent);
    }
    .intro-content {
      padding: 0 var(--space-2xl) 0 var(--space-lg);
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
      max-width: 520px;
    }
    .intro-label {
      font-family: var(--font-mono);
      font-weight: var(--w-base);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-grana);
      line-height: 1.6;
      max-width: 28ch;
    }
    .intro-heading {
      font-family: var(--font-serif);
      font-weight: var(--w-medium);
      font-size: clamp(2.5rem, 4.8vw, 4.4rem);
      line-height: 0.95;
      color: var(--text-dark);
      letter-spacing: -0.005em;
      margin-top: var(--space-xs);
    }
    .intro-body {
      font-family: var(--font-mono);
      font-weight: var(--w-base);
      font-size: 13px;
      line-height: 1.85;
      color: var(--text-muted);
      max-width: 42ch;
      margin-top: var(--space-xs);
    }
    .intro-content .btn {
      margin-top: var(--space-sm);
      align-self: flex-start;
    }
    .btn-outline-grana {
      background: transparent;
      color: var(--text-grana);
      border-color: var(--text-grana);
    }
    .btn-outline-grana:hover {
      background: var(--text-grana);
      color: var(--text-light);
      border-color: var(--text-grana);
    }

    /* ---- RESPONSIVE ---- */
    @media (max-width: 900px) {
      .nav { padding: var(--space-sm); }
      .nav-links { display: none; }
      .float-nav { display: none; }

      .hero-grid {
        grid-template-columns: 1fr;
        padding: var(--space-xl) var(--space-sm) var(--space-sm);
        gap: var(--space-md);
      }
      .hero-circles {
        flex-direction: row;
        justify-content: center;
        order: -1;
      }
      .hero-circle { width: 100px; height: 100px; }
      .hero-col-right { align-items: flex-start; text-align: left; }

      .expo { grid-template-columns: 1fr; }
      .expo-text { padding: var(--space-lg) var(--space-sm); }
      .expo-img { min-height: 260px; }

      .manifesto { padding: var(--space-lg) var(--space-sm); }
      .manifesto-header { grid-template-columns: 1fr; gap: var(--space-md); }
      .manifesto-imgs {
        grid-template-columns: 1fr 1fr;
        height: 320px;
      }
      .manifesto-imgs .manifesto-img:last-child { display: none; }

      .favoritos { padding: var(--space-lg) var(--space-sm); }
      .favoritos-grid { grid-template-columns: 1fr 1fr; }
      .favoritos-word { display: none; }
      .favoritos-cards { grid-column: span 2; }

      .tina-inner { grid-template-columns: 1fr; }
      .tina-text { padding: var(--space-lg) var(--space-sm); }
      .tina-imgs { min-height: 300px; }

      .quote { padding: var(--space-lg) var(--space-sm); }

      .bridge { grid-template-columns: 1fr; }
      .bridge-text { padding: var(--space-lg) var(--space-sm); }
      .bridge-img { min-height: 260px; }

      footer { grid-template-columns: 1fr; text-align: center; }
      .footer-copy { text-align: center; }
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav class="nav" id="nav" aria-label="Principal">
    <a href="/" class="nav-logo" aria-label="Casa de la Grana - inicio">
      <img src="/images/logo-rojo.svg" alt="Casa de la Grana" />
    </a>
    <div class="nav-right">
      <nav class="nav-lang" aria-label="Idioma">
        <a href="/" aria-current="false">EN</a><span aria-hidden="true">/</span><a href="/" aria-current="true"><strong>ES</strong></a>
      </nav>
      <a href="https://nocheztlicalli.com" target="_blank" rel="noopener noreferrer" class="nav-cart" aria-label="Tienda">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 7h14l-1.2 11.4A2 2 0 0 1 15.8 20H8.2a2 2 0 0 1-2-1.6L5 7z"/>
          <path d="M9 7V5a3 3 0 0 1 6 0v2"/>
        </svg>
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <img class="hero-bg" src="/images/img-01-hero.jpg" alt="" loading="eager" />
    <div class="hero-inner">
      <span class="hero-word hero-word-l">Descubre</span>
      <p class="hero-tag hero-tag-tr">Naturaleza, Historia, Cultura</p>
      <p class="hero-tag hero-tag-bl">Tradición, Arte, Preservación</p>
      <span class="hero-word hero-word-r">El Secreto</span>
    </div>
  </section>

  <!-- INTRO / BIENVENIDA -->
  <section class="intro">
    <div class="intro-blob" aria-hidden="true">
      <img src="/images/isotipo-rojo.svg" alt="" />
    </div>
    <div class="intro-content">
      <p class="intro-label">Junto a las guardianas del legado oaxaqueño</p>
      <h2 class="intro-heading">Descubre<br/>el secreto</h2>
      <p class="intro-body">Vive una experiencia inolvidable en Casa de la Grana, donde descubrirás el origen del rojo mexicano y otros colores ancestrales que forman parte del legado del México antiguo.</p>
      <div>
        <a href="#contacto" class="btn btn-outline-grana">Visítanos</a>
      </div>
    </div>
  </section>

  <!-- BRIDGE -->
  <section class="bridge">
    <div class="bridge-text">
      <p class="label label-inv">04 · El proyecto vive</p>
